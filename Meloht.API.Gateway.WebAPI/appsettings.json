{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5500"
      }
    }
  },
  "Gateway": {
    "LoadBalancingPolicy": "RoundRobin",

    "ReverseProxy": {
      "RequestQueuePoolSize": 1000,
      "RequestTimeoutSeconds": 120
    },
    "DatabaseAutoUpdate": {
      "IntervalSeconds": 120,
      "DatabaseTimeoutSeconds": 5,
      "ConnectionString": null
    },
    "HealthCheck": {
      "IntervalSeconds": 10,
      "RequestTimeoutSeconds": 5
    },
    "TargetServers": [
      {
        "Id": 1,
        "UniqueName": "test01",
        "Host": "localhost:8081",
        "Protocol": "http",
        "Weight": 1
      }
