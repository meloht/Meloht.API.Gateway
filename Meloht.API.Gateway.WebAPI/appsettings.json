{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5500"
      }
    }
  },
  "Gateway": {
    "PoolSize": 100,
    "HttpRequestTimeout": 120,
    "LoadBalancingPolicy": "RoundRobin",

    "DatabaseAutoUpdate": {
      "IntervalSeconds": 120,
      "DatabaseTimeoutSeconds": 5,
      "ConnectionString": null
    },
    "HealthCheck": {
      "IntervalSeconds": 10,
      "RequestTimeoutSeconds": 5
    },
    "TargetServers": [
      {
        "Id": 1,
        "UniqueName": "test01",
        "Host": "localhost",
        "Port": 5000,
        "Weight": 1
      }
    ]
  },

  "AllowedHosts": "*"
}
